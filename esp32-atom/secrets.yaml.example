# Copy this file to secrets.yaml (next to spa-atom.yaml) and fill in your values.
# secrets.yaml is gitignored - never commit real credentials.

wifi_ssid: "YourNetwork"
wifi_password: "YourWiFiPassword"

# 32-byte base64 key. Generate one in the ESPHome dashboard (key icon) or:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_key: "CHANGE_ME_base64_32_bytes="

# Any strong random string.
ota_password: "CHANGE_ME"
